{
    "cli": {
        "version": ">= 13.1.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "env": {
                "EXPO_USE_PRECOMPILED_MODULES": "0"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "env": {
                "EXPO_USE_PRECOMPILED_MODULES": "0"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "env": {
                "EXPO_USE_PRECOMPILED_MODULES": "0"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "6745537256"
            }
        }
    }
}
